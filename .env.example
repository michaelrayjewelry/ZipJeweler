# =============================================================================
# ZipJeweler Social Media Agents — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# --- LLM Providers ---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# --- Reddit (PRAW) ---
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=ZipJeweler Social Agent v0.1
REDDIT_USERNAME=
REDDIT_PASSWORD=

# --- X / Twitter (Tweepy) ---
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=
TWITTER_BEARER_TOKEN=

# --- LinkedIn ---
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ACCESS_TOKEN=

# --- Facebook / Instagram (Meta Graph API) ---
META_APP_ID=
META_APP_SECRET=
META_PAGE_ACCESS_TOKEN=
META_PAGE_ID=
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# --- Pinterest ---
PINTEREST_ACCESS_TOKEN=
PINTEREST_BOARD_ID=

# --- Google Sheets ---
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json
GOOGLE_SPREADSHEET_ID=

# --- Image Generation ---
STABILITY_API_KEY=

# --- Notifications ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
NOTIFICATION_EMAIL_TO=

# --- Agent Behavior ---
HUMAN_APPROVAL_REQUIRED=true
DRY_RUN=true
LOG_LEVEL=INFO

# --- Database ---
DATABASE_URL=sqlite:///data/db/zipjeweler.db
